---
type Props = {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
};
const { title, subtitle, align = "left" } = Astro.props;
---

<header class:list={["section-header", `is-${align}`]}>
  <h2>{title}</h2>
  {subtitle && <p class="subtitle">{subtitle}</p>}
</header>

<style>
  .section-header {
    margin-bottom: 2rem;
  }
  .section-header h2 {
    margin-bottom: 0.35rem;
  }
  .subtitle {
    color: var(--color-text-muted);
    max-width: 62ch;
    margin: 0;
    font-size: 1.05rem;
  }
  .is-center {
    text-align: center;
  }
  .is-center .subtitle {
    margin-inline: auto;
  }
</style>
