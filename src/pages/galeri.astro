---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { getSite, getGallery } from "../lib/content";

const site = await getSite();
const items = await getGallery();
---

<BaseLayout
  title={`Galeri — ${site.businessName}`}
  description="HK Motors servisinden ve yaptığımız işlerden bir seçki."
>
  <section class="section section--dark page-hero">
    <div class="container">
      <p class="eyebrow">Galeri</p>
      <h1>Serviste bir gün.</h1>
      <p class="lead">
        Çalıştığımız motosikletler, yedek parça deposu ve servisimizden kareler.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader title="Fotoğraflar" />
      <div class="gallery">
        {
          items.map((g) => (
            <figure class="gallery__item">
              <img
                src={g.data.image}
                alt={g.data.caption ?? ""}
                loading="lazy"
                width="800"
                height="600"
              />
              {g.data.caption && <figcaption>{g.data.caption}</figcaption>}
            </figure>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding-block: clamp(3rem, 6vw, 5rem); }
  .page-hero .lead {
    color: var(--color-on-dark-muted);
    max-width: 60ch;
    font-size: 1.05rem;
  }
  .eyebrow {
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.75rem;
  }
  .gallery__item {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-dark);
    position: relative;
  }
  .gallery__item img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .gallery__item:hover img {
    transform: scale(1.03);
  }
  .gallery__item figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0.6rem 0.9rem;
    background: linear-gradient(
      to top,
      rgba(20, 22, 26, 0.85),
      rgba(20, 22, 26, 0)
    );
    color: var(--color-on-dark);
    font-size: 0.9rem;
    font-family: var(--font-heading);
    font-weight: 600;
  }
</style>
