---
import BaseLayout from "../layouts/BaseLayout.astro";
import { waLink } from "../lib/site";
import { getSite } from "../lib/content";

const site = await getSite();
---

<BaseLayout
  title={`Sayfa bulunamadı — ${site.businessName}`}
  description="Aradığınız sayfa taşınmış veya kaldırılmış olabilir."
  noindex={true}
>
  <section class="section section--dark not-found">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>Bu sayfa bulunamadı.</h1>
      <p class="lead">
        Aradığınız sayfa taşınmış veya kaldırılmış olabilir. Ana sayfaya
        dönebilir ya da doğrudan bize ulaşabilirsiniz.
      </p>
      <div class="ctas">
        <a class="btn btn--accent" href="/">Ana sayfaya dön</a>
        <a
          class="btn btn--whatsapp"
          href={waLink(site.phoneWhatsapp, site.defaultWhatsappMessage)}
          target="_blank"
          rel="noopener"
        >
          WhatsApp
        </a>
        <a class="btn btn--ghost" href={`tel:${site.phonePrimaryTel}`}>
          {site.phonePrimary}
        </a>
      </div>

      <nav class="quick-links" aria-label="Hızlı bağlantılar">
        <span>Popüler sayfalar:</span>
        <a href="/hizmetler">Hizmetler</a>
        <a href="/urunler">Ürünler</a>
        <a href="/iletisim">İletişim</a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding-block: clamp(4rem, 10vw, 7rem);
    text-align: center;
  }
  .not-found .container { max-width: 640px; }
  .eyebrow {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    color: var(--color-accent);
    margin: 0 0 0.25rem;
    line-height: 1;
  }
  .lead {
    color: var(--color-on-dark-muted);
    font-size: 1.1rem;
    max-width: 55ch;
    margin-inline: auto;
  }
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin: 2rem 0 1.5rem;
  }
  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    justify-content: center;
    align-items: center;
    color: var(--color-on-dark-muted);
    font-size: 0.95rem;
  }
  .quick-links a {
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
