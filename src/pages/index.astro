---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProductCard from "../components/ProductCard.astro";
import ReviewCard from "../components/ReviewCard.astro";
import { waLink } from "../lib/site";
import {
  getSite,
  getHome,
  getServices,
  getProducts,
  getReviews,
} from "../lib/content";

const site = await getSite();
const home = await getHome();
const services = await getServices();
const products = await getProducts();
const reviews = await getReviews();

const featuredServices = services.filter((s) => s.data.featured).slice(0, 4);
const featuredProducts = products.filter((p) => p.data.featured).slice(0, 4);
const featuredReviews = reviews.filter((r) => r.data.featured).slice(0, 3);
---

<BaseLayout
  title={`${site.businessName} — ${site.tagline}`}
  description="Yeşilpınar İstanbul HK Motors: motosiklet bakım, onarım, yağ ve filtre değişimi, lastik, fren, motor revizyonu ve 7/24 yol yardımı. Uzun yıllara dayanan tecrübe, uygun fiyat."
>
  {/* ── Hero ─────────────────────────────────────────── */}
  <section class="section section--dark hero" aria-label="HK Motors — anasayfa">
    <img
      class="hero__bg"
      src="/images/hero.webp"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      width="1920"
      height="1280"
    />
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{home.heroEyebrow}</p>
        <h1>{home.heroHeading}</h1>
        <p class="lead">{home.heroSubtext}</p>
        <div class="hero-ctas">
          <a class="btn btn--accent" href={`tel:${site.phonePrimaryTel}`}>
            {home.primaryCtaLabel}
          </a>
          <a
            class="btn btn--whatsapp"
            href={waLink(site.phoneWhatsapp, site.defaultWhatsappMessage)}
            target="_blank"
            rel="noopener"
          >
            {home.whatsappCtaLabel}
          </a>
        </div>
        <p class="muted small">
          {site.hoursText} · {site.roadsideAreaText}
        </p>
      </div>
    </div>
  </section>

  {/* ── Featured services ────────────────────────────── */}
  <section class="section">
    <div class="container">
      <SectionHeader
        title={home.servicesSectionTitle}
        subtitle={home.servicesSectionSubtitle}
      />
      <div class="grid grid--services">
        {
          featuredServices.map((s) => (
            <ServiceCard title={s.data.title} description={s.data.description} />
          ))
        }
      </div>
      <p class="section-cta">
        <a class="btn btn--outline" href="/hizmetler">Tüm hizmetler →</a>
      </p>
    </div>
  </section>

  {/* ── Featured products ────────────────────────────── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeader
        title={home.productsSectionTitle}
        subtitle={home.productsSectionSubtitle}
      />
      <div class="grid grid--products">
        {
          featuredProducts.map((p) => (
            <ProductCard
              name={p.data.name}
              category={p.data.category}
              price={p.data.price}
              image={p.data.image}
              description={p.data.description}
              brand={p.data.brand}
              model={p.data.model}
              year={p.data.year}
              km={p.data.km}
              engineCc={p.data.engineCc}
              condition={p.data.condition}
            />
          ))
        }
      </div>
      <p class="section-cta">
        <a class="btn btn--outline" href="/urunler">Tüm ürünler →</a>
      </p>
    </div>
  </section>

  {/* ── Reviews snippet ─────────────────────────────── */}
  {featuredReviews.length > 0 && (
    <section class="section">
      <div class="container">
        <SectionHeader title={home.reviewsSectionTitle} align="center" />
        <div class="grid grid--reviews">
          {featuredReviews.map((r) => (
            <ReviewCard
              author={r.data.author}
              rating={r.data.rating}
              text={r.data.text}
              date={r.data.date}
            />
          ))}
        </div>
        <p class="section-cta">
          <a class="btn btn--outline" href="/yorumlar">Tüm yorumlar →</a>
        </p>
      </div>
    </section>
  )}

  {/* ── Roadside emergency CTA ──────────────────────── */}
  <section class="section section--dark closing" aria-label="Yol yardımı çağrısı">
    <img
      class="closing__bg"
      src="/images/yol-yardimi.webp"
      alt=""
      aria-hidden="true"
      loading="lazy"
      width="1400"
      height="933"
    />
    <div class="container closing-inner">
      <div>
        <p class="eyebrow">{site.roadsideAreaText}</p>
        <h2>{home.closingHeading}</h2>
        <p class="lead">{home.closingSubtext}</p>
      </div>
      <div class="closing-ctas">
        <a class="btn btn--accent btn--lg" href={`tel:${site.phonePrimaryTel}`}>
          {site.stickyCtaLabel}
        </a>
        <a
          class="btn btn--whatsapp"
          href={waLink(site.phoneWhatsapp, site.defaultWhatsappMessage)}
          target="_blank"
          rel="noopener"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero with dark image + gradient overlay ─────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 10vw, 7rem);
    isolation: isolate;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -2;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(20, 22, 26, 0.55) 0%, rgba(20, 22, 26, 0.85) 100%),
      linear-gradient(90deg, rgba(20, 22, 26, 0.65) 0%, rgba(20, 22, 26, 0.25) 100%);
    z-index: -1;
  }
  .hero-grid { display: grid; gap: 2rem; max-width: 780px; position: relative; }

  .eyebrow {
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }
  .lead {
    font-size: 1.1rem;
    color: var(--color-on-dark-muted);
    max-width: 60ch;
  }
  .hero h1,
  .closing h1,
  .closing h2 {
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block: 1.5rem 1rem;
  }
  .muted { color: var(--color-on-dark-muted); }
  .small { font-size: 0.9rem; }

  .grid { display: grid; gap: 1.25rem; }
  .grid--services { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .grid--products { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .grid--reviews  { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }

  .section-cta {
    text-align: center;
    margin-top: 2rem;
  }

  /* ── Roadside emergency CTA with image bg ────────────────────────────── */
  .closing {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-block: clamp(3.5rem, 8vw, 5.5rem);
  }
  .closing__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -2;
  }
  .closing::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(20, 22, 26, 0.7) 0%, rgba(20, 22, 26, 0.9) 100%),
      linear-gradient(90deg, rgba(20, 22, 26, 0.75) 0%, rgba(20, 22, 26, 0.35) 100%);
    z-index: -1;
  }
  .closing-inner {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    align-items: center;
    position: relative;
  }
  .closing h2 { margin-bottom: 0.5rem; }
  .closing .lead { color: var(--color-on-dark-muted); }
  .closing-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  :global(.btn--lg) {
    padding: 1rem 1.5rem;
    font-size: 1.05rem;
    min-height: 56px;
  }

  @media (min-width: 700px) {
    .closing-inner { grid-template-columns: 1fr auto; }
  }
</style>
